# Строка подключения к PostgreSQL для blog-server и blog-migration.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/blog_db

# Секрет для подписи JWT-токенов. Для реального окружения используйте длинное случайное значение.
JWT_SECRET=replace-with-at-least-32-random-characters

# Настройки HTTP-сервера.
HOST=127.0.0.1
PORT=8080

# Настройки gRPC-сервера.
GRPC_PORT=50051

# Время жизни JWT-токена в секундах.
JWT_TTL_SECONDS=3600

# Разрешенные origins через запятую. `*` удобно для локальной разработки.
CORS_ORIGINS=*

# Base URL HTTP API для WASM-фронтенда.
# Используется на этапе сборки/запуска Dioxus, backend эту переменную игнорирует.
BLOG_API_BASE_URL=http://127.0.0.1:8080/api
